# Local / deployment configuration
# Copy to .env and adjust values for your environment.

# Dashboard -> FastAPI base URL (Streamlit service)
API_BASE_URL=http://127.0.0.1:8001

# PostgreSQL (backend service)
DATABASE_URL=postgresql://crisis_user:crisis_password@127.0.0.1:5433/crisis_resource_db
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=crisis_resource_db
POSTGRES_USER=crisis_user
POSTGRES_PASSWORD=crisis_password

# Public data ingestion
RELIEFWEB_API_URL=https://api.reliefweb.int/v2/reports
RELIEFWEB_APPNAME=your_reliefweb_appname_here
GDACS_RSS_URL=https://www.gdacs.org/xml/rss.xml

# Optional local API bind settings
API_HOST=0.0.0.0
API_PORT=8000
